        "metadata": {},
        "script": {
          "image": "harbor-srep01.ttttt.com/aistudio/ubuntu2404-uv-py39-py314-wf-py313:0.0.6",
          "command": [
            "/usr/local/bin/uv",
            "run",
            "python"
          ],
          "source": "import re\n\ndef parse_repository_name(url):\n    normalized = url.rstrip('/').removesuffix('.git')\n    name = normalized.rsplit('/', 1)[-1]\n    if not re.fullmatch(r'[A-Za-z0-9._-]+', name):\n        raise ValueError(f'invalid repository name: {name}')\n    return name\n\nuser_code = parse_repository_name(r'''{{inputs.parameters.bitbucket-address-user-code}}''')\ndocker_template = parse_repository_name(r'''{{inputs.parameters.bitbucket-address-docker-template}}''')\n\nwith open('/tmp/repo-name-user-code.txt', 'w', encoding='utf-8') as file:\n    file.write(user_code)\n\nwith open('/tmp/repo-name-docker-template.txt', 'w', encoding='utf-8') as file:\n    file.write(docker_template)\n"
        }
      },
      {
        "name": "check-zeus-speed",
        "inputs": {
          "parameters": [
            {
              "name": "zeus-pypi-url"
            },
            {
              "name": "slow-threshold-seconds"
            }
          ]
        },
        "outputs": {
