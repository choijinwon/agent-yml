            {
              "name": "zeus-speed-report",
              "path": "/tmp/zeus-speed-report.json",
              "archive": {
                "none": {}
              }
            }
          ]
        },
        "metadata": {},
        "script": {
          "image": "harbor-srep01.ttttt.com/aistudio/ubuntu2404-uv-py39-py314-wf-py313:0.0.6",
          "command": [
            "/usr/local/bin/uv",
            "run",
            "python"
          ],
          "env": [
            {
              "name": "ZEUS_USERNAME",
              "valueFrom": {
                "secretKeyRef": {
                  "name": "zeus-pypi-auth",
                  "key": "username"
                }
              }
            },
            {
              "name": "ZEUS_PASSWORD",
              "valueFrom": {
                "secretKeyRef": {
                  "name": "zeus-pypi-auth",
                  "key": "password"
                }
              }
            }
          ],
          "source": "import base64\nimport json\nimport os\nimport time\nimport urllib.request\nfrom datetime import datetime, timezone\nfrom urllib.parse import urlsplit\n\nurl = r'''{{inputs.parameters.zeus-pypi-url}}'''.strip()\nthreshold = float(r'''{{inputs.parameters.slow-threshold-seconds}}''')\nif not url.startswith(('http://', 'https://')):\n    raise ValueError('zeus-pypi-url must start with http:// or https://')\nif threshold <= 0:\n    raise ValueError('slow-threshold-seconds must be greater than zero')\n\nusername = os.environ['ZEUS_USERNAME']\npassword = os.environ['ZEUS_PASSWORD']\ntoken = base64.b64encode(f'{username}:{password}'.encode()).decode()\nrequest = urllib.request.Request(\n    url,\n    headers={\n        'Authorization': f'Basic {token}',\n        'User-Agent': 'argo-zeus-speed-check/1.0'\n    }\n)\n\nstarted = time.perf_counter()\nwith urllib.request.urlopen(request, timeout=30) as response:\n    http_status = response.status\n    body = response.read()\ntotal_seconds = time.perf_counter() - started\ndownload_bytes = len(body)\ndownload_speed = download_bytes / max(total_seconds, 0.001)\nspeed_status = 'OK' if total_seconds <= threshold else 'SLOW'\n\nreport = {\n    'timestamp': datetime.now(timezone.utc).isoformat(),\n    'host': urlsplit(url).hostname,\n    'httpStatus': http_status,\n    'totalSeconds': round(total_seconds, 6),\n    'downloadBytes': download_bytes,\n    'downloadSpeedBytesPerSecond': round(download_speed, 2),\n    'slowThresholdSeconds': threshold,\n    'speedStatus': speed_status\n}\n\nwith open('/tmp/zeus-speed-report.json', 'w', encoding='utf-8') as file:\n    json.dump(report, file, ensure_ascii=False, separators=(',', ':'))\nwith open('/tmp/zeus-total-seconds.txt', 'w', encoding='utf-8') as file:\n    file.write(str(report['totalSeconds']))\nwith open('/tmp/zeus-download-bytes.txt', 'w', encoding='utf-8') as file:\n    file.write(str(download_bytes))\nwith open('/tmp/zeus-download-speed.txt', 'w', encoding='utf-8') as file:\n    file.write(str(report['downloadSpeedBytesPerSecond']))\nwith open('/tmp/zeus-speed-status.txt', 'w', encoding='utf-8') as file:\n    file.write(speed_status)\n\nprint(json.dumps(report, ensure_ascii=False))\n"
        }
      },
