          ]
        },
        "script": {
          "image": "harbor-srep01.ttttt.com/aistudio/ubuntu2404-uv-py39-py314-wf-py313:0.0.6",
          "command": [
            "/usr/local/bin/uv",
            "run",
            "python"
          ],
          "source": "import re\n\ndigest = r'''{{inputs.parameters.image-digest}}'''.strip()\nmatch = re.search(r'sha256:[0-9a-fA-F]{64}', digest)\nif not match:\n    raise ValueError('valid sha256 image digest was not found')\n\nwith open('/tmp/parsed-image-digest.txt', 'w', encoding='utf-8') as file:\n    file.write(match.group(0).lower())\n"
        }
