              "name": "user-code-repo-name",
              "valueFrom": {
                "path": "/tmp/repo-name-user-code.txt"
              }
            },
            {
              "name": "docker-template-repo-name",
              "valueFrom": {
                "path": "/tmp/repo-name-docker-template.txt"
              }
            }
